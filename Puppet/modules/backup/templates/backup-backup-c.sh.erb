#!/bin/bash

WRAPPER=/usr/local/lib/backup/rsync-to-backup.sh


## Backup specific

"$WRAPPER" node_exporter /usr/local/bin/node_exporter

"$WRAPPER" prometheus-cfg /usr/local/bin/prometheus/

"$WRAPPER" prometheus-data /var/lib/prometheus/

"$WRAPPER" grafana-cfg /etc/grafana

"$WRAPPER" grafana-data /var/lib/grafana

# All

"$WRAPPER" syslog /etc/rsyslog.d/

"$WRAPPER" crontab /var/spool/cron/crontabs/

"$WRAPPER" ufw /etc/ufw

"$WRAPPER" hosts /etc/hosts

"$WRAPPER" dns /etc/resolv.conf



