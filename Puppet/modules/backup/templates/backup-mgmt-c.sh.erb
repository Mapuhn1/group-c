#!/bin/bash

WRAPPER=/usr/local/lib/backup/rsync-to-backup.sh

# Management specific

"$WRAPPER" puppet-etc /etc/puppetlabs/

"$WRAPPER" puppet-opt /opt/puppetlabs/

"$WRAPPER" remote-logs /var/log/remote/

# All
"$WRAPPER" syslog /etc/rsyslog.d/

"$WRAPPER" crontab /var/spool/cron/crontabs/

"$WRAPPER" ufw /etc/ufw

"$WRAPPER" hosts /etc/hosts

"$WRAPPER" dns /etc/resolv.conf

# Machines that backup to backup

"$WRAPPER" backup-keys /root/.ssh 
