global:
  scrape_interval: 15s
  evaluation_interval: 15s

alerting:
  alertmanagers:
    - static_configs:
        - targets: []

rule_files:
  - "/usr/local/bin/prometheus/rule1.yml"
  - "/usr/local/bin/prometheus/rule2.yml"

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "node-exporter"
    static_configs:
      - targets: ["localhost:9100", "10.2.0.5:9100", "10.2.0.6:9100", "10.2.0.7:9100"]
